# =============================================================================
# GetUrLink server configuration — TEMPLATE
# Copy this file to `.env` and fill in real values. NEVER commit the real .env.
# =============================================================================

# ---- Environment -----------------------------------------------------------
# Use "development" ONLY on your local machine. On the live server set this to
# "production" (or leave it unset — the app defaults to production behaviour).
# Dev mode enables mock checkout, unsigned webhooks, and DB seeding.
NODE_ENV=development

# ---- Server ----------------------------------------------------------------
PORT=5050

# Public base URL of THIS server (used to build Stripe redirect/callback URLs).
# Local: http://localhost:5050  |  Prod: https://api.yourdomain.com
API_URL=http://localhost:5050

# URL of the front-end app (used for CORS allow-list and post-checkout redirects).
# Local: http://localhost:5173  |  Prod: https://app.yourdomain.com
FRONTEND_URL=http://localhost:5173

# ---- Auth (REQUIRED) -------------------------------------------------------
# The server refuses to start without this. Use a long random string in prod,
# e.g. generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret

# ---- Stripe — payments -----------------------------------------------------
# Replace the placeholders below with your real keys from the Stripe Dashboard.
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Webhook signing secret (Stripe Dashboard → Developers → Webhooks).
# REQUIRED in production — webhooks are rejected without a valid signature.
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_signing_secret_here

# Stripe Connect OAuth client id (for routing seller payouts). Optional in dev
# (a mock account is used); required for real Connect payouts in production.
STRIPE_CLIENT_ID=your_stripe_connect_client_id_here

# Recurring price id for the Premium creator subscription. Optional in dev
# (a direct mock upgrade is used); required for real subscriptions in prod.
STRIPE_PREMIUM_PRICE_ID=your_stripe_premium_price_id_here

# ---- AI assistant ----------------------------------------------------------
# Google Gemini API key for the storefront chat assistant. If unset, the app
# falls back to local keyword-matching (no external calls).
GEMINI_API_KEY=
